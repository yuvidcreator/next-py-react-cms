# =============================================================================
# PyPress CMS — Git Ignore
# =============================================================================

# ── Environment (NEVER commit secrets — like wp-config.php) ──────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────────────────
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
**/versions/

# ── Node.js ──────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.nuxt/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker ───────────────────────────────────────────────────────────────
# Volume data (managed by Docker, not by git)
pgdata/
redis-data/

# ── Backups ──────────────────────────────────────────────────────────────
backups/*.dump
backups/*.sql
backups/*.gz

# ── Uploads (user media — like wp-content/uploads/) ─────────────────────
uploads/

# ── Logs ─────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / Editor ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── SSL certificates (never commit private keys) ────────────────────────
docker/nginx/ssl/*.pem
docker/nginx/ssl/*.key
docker/nginx/ssl/*.crt

# ── OS Files ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
