# PyPress Environment Configuration (wp-config.php equivalent)
APP_NAME=PyPress
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-this-to-64-char-random-string

# Database
DATABASE_URL=postgresql+asyncpg://pypress:pypress_dev_password@localhost:5432/pypress

# Auth (httpOnly Cookie-Based JWT)
JWT_SECRET=change-this-to-another-64-char-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_SECRET=change-this-to-yet-another-64-char-random-string

# OAuth2.0 Social Login (configure when needed)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Plugins & Themes
PLUGINS_DIR=backend/plugins/installed
THEMES_DIR=backend/themes/installed
ACTIVE_THEME=developer_default
AUTO_ACTIVATE_PLUGINS=["hello_world"]

# Cache
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
